# Copia este fichero a .env y rellena los valores para tu entorno local
# Nunca commitear el .env real — está en .gitignore

# URL base de la API bajo prueba
BASE_URL=https://tu-api.com

# URL del spec OpenAPI (si es distinta de BASE_URL/openapi.json)
# OPENAPI_SPEC_URL=https://raw.githubusercontent.com/tu-org/tu-repo/main/swagger.json

# Entorno activo
ENV=local

# Credenciales (si la API requiere autenticación)
# API_KEY=
# API_USER=
# API_PASSWORD=

# Ruta raíz del proyecto (usada por el servidor MCP)
API_TESTING_ROOT=/Users/jorgemartinezortega/Desktop/testing/claude/api-testing

# Thresholds de rendimiento
RESPONSE_TIME_THRESHOLD_MS=2000
