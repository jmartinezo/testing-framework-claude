# Copia este fichero a .env y rellena los valores para tu entorno local
# Nunca commitear el .env real — está en .gitignore

# URL base de la aplicación bajo prueba
BASE_URL=https://tu-aplicacion.com

# Entorno activo
ENV=local

# Headless — false para ver el navegador en local, true en CI
HEADLESS=true
